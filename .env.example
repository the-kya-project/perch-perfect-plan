# Copy to .env and fill in. .env is gitignored — never commit real values.
#
# ---- Supabase (required) ----
# Client-safe values only: the URL and the PUBLISHABLE (anon) key ship to the
# browser by design. NEVER put the service_role key here — it lives only in the
# server env (Vercel / Supabase function secrets). The VITE_-prefixed copies are
# what the client build reads; the unprefixed copies are for server/tooling.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PROJECT_ID=your-project-ref
SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PROJECT_ID=your-project-ref
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key

# ---- Analytics (privacy-friendly) ----
# Drop in either a PostHog key OR a Plausible domain. The app picks up the
# values at build time — no code changes required. When neither is set, all
# tracking calls are silent no-ops.

# PostHog
# VITE_ANALYTICS_PROVIDER=posthog
# VITE_POSTHOG_KEY=phc_your_project_key_here
# VITE_POSTHOG_HOST=https://us.i.posthog.com   # or https://eu.i.posthog.com

# Plausible
# VITE_ANALYTICS_PROVIDER=plausible
# VITE_PLAUSIBLE_DOMAIN=app.example.com
# VITE_PLAUSIBLE_HOST=https://plausible.io
